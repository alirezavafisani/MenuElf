# OpenAI API key for chat and embeddings
OPENAI_API_KEY=your_openai_api_key_here

# Google Maps/Places API key for restaurant photos
# Required by: backend/scripts/fetch_google_photos.py (to fetch photo references)
# Optional at runtime: backend/main.py (to construct photo URLs in /restaurants response)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Supabase credentials for user intelligence features
SUPABASE_URL=your_supabase_url_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
