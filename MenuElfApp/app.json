{
    "expo": {
        "name": "MenuElf",
        "slug": "menuelf",
        "version": "1.0.0",
        "orientation": "portrait",
        "icon": "./assets/images/icon.png",
        "scheme": "menuelfapp",
        "userInterfaceStyle": "automatic",
        "newArchEnabled": true,
        "ios": {
            "supportsTablet": false,
            "bundleIdentifier": "com.alirezavafi.menuelf",
            "infoPlist": {
                "NSLocationWhenInUseUsageDescription": "Allow MenuElf to use your location to find nearby restaurants on the map."
            }
        },
        "android": {
            "package": "com.alirezavafi.menuelf",
            "adaptiveIcon": {
                "backgroundColor": "#E6F4FE",
                "foregroundImage": "./assets/images/android-icon-foreground.png",
                "backgroundImage": "./assets/images/android-icon-background.png",
                "monochromeImage": "./assets/images/android-icon-monochrome.png"
            },
            "edgeToEdgeEnabled": true,
            "predictiveBackGestureEnabled": false,
            "permissions": [
                "ACCESS_COARSE_LOCATION",
                "ACCESS_FINE_LOCATION"
            ]
        },
        "web": {
            "output": "static",
            "favicon": "./assets/images/favicon.png",
            "config": {
                "googleMaps": {
                    "apiKey": "AIzaSyAlNXWy4c6rHFcnPPxMsMwscOm2yRcf9Cw"
                }
            }
        },
        "plugins": [
            "expo-router",
            [
                "expo-location",
                {
                    "locationAlwaysAndWhenInUsePermission": "Allow MenuElf to use your location to find nearby restaurants on the map."
                }
            ],
            [
                "expo-splash-screen",
                {
                    "image": "./assets/images/splash-icon.png",
                    "imageWidth": 200,
                    "resizeMode": "contain",
                    "backgroundColor": "#ffffff",
                    "dark": {
                        "backgroundColor": "#000000"
                    }
                }
            ]
        ],
        "experiments": {
            "typedRoutes": true,
            "reactCompiler": true
        }
    }
}